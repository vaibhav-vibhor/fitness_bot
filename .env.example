# Fitbit OAuth Credentials
# Get these from https://dev.fitbit.com/apps
CLIENT_ID=your_fitbit_client_id_here
CLIENT_SECRET=your_fitbit_client_secret_here

# Google Gemini API Key
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
# Generate a secure secret key (32+ characters)
SECRET_KEY=your-very-long-random-secret-key-here

# Environment settings
FLASK_ENV=development
DEBUG=True

# Optional: Customize port (default is 3000)
# PORT=3000